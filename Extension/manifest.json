{
  "manifest_version": 3,
  "name": "Nano EVO",
  "version": "6.522.14.49",
"icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "sidePanel", 
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>" 
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Nano EVO" },
  "side_panel": { "default_path": "sidepanel.html" }
}